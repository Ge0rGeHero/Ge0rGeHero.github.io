---
import type { CollectionEntry } from "astro:content";
import PostPage from "@components/features/posts/PostPage.astro";
import TagBar from "@components/features/tags/TagBar.astro";
import TagCloud from "@components/features/tags/TagCloud.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPosts, getTagList } from "@utils/content-utils";
import { initPostIdMap } from "@utils/permalink-utils";
import { getTagUrl } from "@utils/url-utils";
import type { GetStaticPaths, Page } from "astro";

export const getStaticPaths = (async () => {
	const tags = await getTagList();
	return [
		{ params: { tag: undefined } },
		...tags.map((t) => ({ params: { tag: t.name } })),
	];
}) satisfies GetStaticPaths;

const { tag } = Astro.params;
const isIndex = !tag;

const allTags = await getTagList();
const allPosts = await getSortedPosts();
initPostIdMap(allPosts);

let title: string;
let pageData: Page<CollectionEntry<"posts">> | undefined;
if (isIndex) {
	title = i18n(I18nKey.tags);
} else {
	const tagName = tag as string;
	title = `${i18n(I18nKey.tags)}: ${tagName}`;
	const filteredPosts = allPosts.filter((p) =>
		p.data.tags?.some((t) => t.toLowerCase() === tagName.toLowerCase()),
	);
	pageData = {
		data: filteredPosts,
		currentPage: 1,
		lastPage: 1,
		start: 0,
		end: filteredPosts.length,
		size: filteredPosts.length,
		total: filteredPosts.length,
		url: {
			current: getTagUrl(tagName),
			next: undefined,
			prev: undefined,
			first: undefined,
			last: undefined,
		},
	};
}
---

<MainGridLayout title={title}>
	{
		isIndex ? (
			<TagCloud tags={allTags} />
		) : (
			<>
				<TagBar tags={allTags} currentTag={tag} />
				<PostPage page={pageData} />
			</>
		)
	}
</MainGridLayout>
